@page "/workouts"
@rendermode InteractiveServer
@using Forged.Data
@using Forged.Models
@inject AppDbContext Db
@inject NavigationManager Nav

<PageTitle>FORGED – Workouts</PageTitle>

<div class="page-header">
    <h1>Workouts</h1>
    <div style="display:flex;gap:12px;align-items:center;">
        <select class="form-control" style="width:180px;" @bind="filterType" @bind:after="LoadWorkouts">
            <option value="">All Activities</option>
            @foreach (var type in Enum.GetValues<ActivityType>())
            {
                <option value="@type">@GetActivityName(type)</option>
            }
        </select>
        <a href="/workouts/create" class="btn-primary">+ Log Workout</a>
    </div>
</div>

@if (!workouts.Any())
{
    <div class="empty-state">
        <p>No workouts logged yet.</p>
        <a href="/workouts/create" class="btn-primary">Log your first workout</a>
    </div>
}
else
{
    @foreach (var w in workouts)
    {
        <div class="workout-item">
            <div class="workout-item-left">
                <span class="badge @GetBadgeClass(w.ActivityType)">@GetActivityName(w.ActivityType)</span>
                <span class="workout-date">@w.Date.ToString("MMM dd, yyyy")</span>
                @if (!string.IsNullOrEmpty(w.Notes))
                {
                    <span class="text-muted" style="font-size:13px;">@w.Notes</span>
                }
            </div>
            <div class="workout-item-right">
                <a href="/workouts/details/@w.Id" class="btn-ghost">View</a>
                <a href="/workouts/edit/@w.Id" class="btn-ghost">Edit</a>
                <button class="btn-danger" @onclick="() => ConfirmDelete(w.Id)">Delete</button>
            </div>
        </div>
    }

    @if (showConfirm)
    {
        <div class="delete-confirm" style="position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:1000;max-width:400px;width:100%;">
            <div>
                <p style="color:var(--text-primary);font-weight:600;">Delete workout?</p>
                <p class="text-muted" style="font-size:13px;">This action cannot be undone.</p>
            </div>
            <div style="display:flex;gap:8px;">
                <button class="btn-danger" @onclick="DeleteConfirmed">Delete</button>
                <button class="btn-secondary" @onclick="() => showConfirm = false">Cancel</button>
            </div>
        </div>
    }
}

@code {
    private List<WorkoutSession> workouts = new();

    private bool showConfirm = false;
    private int deleteId;

    private string filterType = "";

    private void LoadWorkouts()
    {
        var query = Db.WorkoutSessions.AsQueryable();

        if (!string.IsNullOrEmpty(filterType) &&
            Enum.TryParse<ActivityType>(filterType, out var type))
        {
            query = query.Where(w => w.ActivityType == type);
        }

        workouts = query
            .OrderByDescending(w => w.Date)
            .ToList();
    }

    private void ConfirmDelete(int id)
    {
        deleteId = id;
        showConfirm = true;
    }

    private void DeleteConfirmed()
    {
        Delete(deleteId);
        showConfirm = false;
    }

    protected override void OnInitialized()
    {
        LoadWorkouts();
    }

    // private void LoadWorkouts()
    // {
    //     workouts = Db.WorkoutSessions
    //         .OrderByDescending(w => w.Date)
    //         .ToList();
    // }

    private void Delete(int id)
    {
        var w = Db.WorkoutSessions.Find(id);
        if (w != null)
        {
            var details = Db.ActivityDetails
                .Where(a => a.WorkoutSessionId == id)
                .ToList();
            Db.ActivityDetails.RemoveRange(details);
            Db.WorkoutSessions.Remove(w);
            Db.SaveChanges();
            LoadWorkouts();
        }
    }


    private string GetBadgeClass(ActivityType? t) => t switch
    {
        ActivityType.Gym => "badge-gym",
        ActivityType.HomeWorkout => "badge-homeworkout",
        ActivityType.Calisthenics => "badge-calisthenics",
        ActivityType.Running => "badge-running",
        ActivityType.Cycling => "badge-cycling",
        ActivityType.Yoga => "badge-yoga",
        ActivityType.TeamSport => "badge-teamsport",
        ActivityType.Tennis => "badge-tennis",
        ActivityType.Swimming => "badge-swimming",
        _ => "badge-other"
    };

    private string GetActivityName(ActivityType? t) => t switch
    {
        ActivityType.HomeWorkout => "Home Workout",
        ActivityType.TeamSport => "Team Sport",
        _ => t?.ToString() ?? "Unknown"
    };
}