@page "/workouts/edit/{Id:int}"
@rendermode InteractiveServer
@using Forged.Data
@using Forged.Models
@inject AppDbContext Db
@inject NavigationManager Nav

<PageTitle>FORGED – Edit Workout</PageTitle>

<div class="page-header">
    <h1>Edit Workout</h1>
</div>

@if (session == null)
{
    <p class="text-muted">Loading...</p>
}
else
{
    <div class="card" style="max-width:700px;">
        <div class="form-group">
            <label class="form-label">Date</label>
            <input type="date" class="form-control" @bind="session.Date" />
        </div>

        <div class="form-group">
            <label class="form-label">Activity Type</label>
            <select class="form-control" @bind="session.ActivityType">
                @foreach (var type in Enum.GetValues<ActivityType>())
                {
                    <option value="@type">@GetActivityName(type)</option>
                }
            </select>
        </div>

        <hr class="divider" />

        @if (session.ActivityType == ActivityType.Gym ||
                     session.ActivityType == ActivityType.HomeWorkout ||
                     session.ActivityType == ActivityType.Calisthenics)
        {
            <div class="exercise-section">
                <label class="form-label">Exercises</label>
                @foreach (var ex in exercises)
                {
                    <div class="exercise-row">
                        <input class="form-control" placeholder="Exercise name" @bind="ex.Name" />
                        <input class="form-control" type="number" placeholder="Sets" @bind="ex.Sets" />
                        <input class="form-control" type="number" placeholder="Reps" @bind="ex.Reps" />
                        <input class="form-control" type="number" placeholder="kg" @bind="ex.Weight" />
                        <button class="btn-danger" @onclick="() => exercises.Remove(ex)">✕</button>
                    </div>
                }
                <button class="add-exercise-btn" @onclick="AddExercise">+ Add Exercise</button>
            </div>
        }
        else if (session.ActivityType == ActivityType.Running ||
                 session.ActivityType == ActivityType.Cycling)
        {
            <div class="form-group">
                <label class="form-label">Distance (km)</label>
                <input class="form-control" type="number" step="0.1" @bind="distance" />
            </div>
            <div class="form-group">
                <label class="form-label">Duration (min)</label>
                <input class="form-control" type="number" @bind="duration" />
            </div>
        }
        else if (session.ActivityType == ActivityType.Yoga)
        {
            <div class="form-group">
                <label class="form-label">Duration (min)</label>
                <input class="form-control" type="number" @bind="duration" />
            </div>
            <div class="form-group">
                <label class="form-label">Style (e.g. Vinyasa, Hatha)</label>
                <input class="form-control" @bind="style" />
            </div>
        }
        else if (session.ActivityType == ActivityType.TeamSport ||
                 session.ActivityType == ActivityType.Tennis)
        {
            <div class="form-group">
                <label class="form-label">Duration (min)</label>
                <input class="form-control" type="number" @bind="duration" />
            </div>
            <div class="form-group">
                <label class="form-label">Opponent (optional)</label>
                <input class="form-control" @bind="opponent" />
            </div>
            <div class="form-group">
                <label class="form-label">Result</label>
                <select class="form-control" @bind="result">
                    <option value="">– Select –</option>
                    <option value="Win">Win</option>
                    <option value="Loss">Loss</option>
                    <option value="Draw">Draw</option>
                </select>
            </div>
        }
        else if (session.ActivityType == ActivityType.Swimming)
        {
            <div class="form-group">
                <label class="form-label">Distance (m)</label>
                <input class="form-control" type="number" @bind="distance" />
            </div>
            <div class="form-group">
                <label class="form-label">Duration (min)</label>
                <input class="form-control" type="number" @bind="duration" />
            </div>
        }
        else
        {
            <div class="form-group">
                <label class="form-label">Duration (min)</label>
                <input class="form-control" type="number" @bind="duration" />
            </div>
        }

        <hr class="divider" />

        <div class="form-group">
            <label class="form-label">Notes</label>
            <textarea class="form-control" rows="3" @bind="session.Notes"></textarea>
        </div>

        <div class="form-actions">
            <button class="btn-primary" @onclick="Save">Save Changes</button>
            <a href="/workouts/details/@Id" class="btn-secondary">Cancel</a>
        </div>

        <div class="delete-confirm">
            <span class="text-muted" style="font-size:13px;">Danger zone</span>
            <button class="btn-danger" @onclick="Delete">Delete Workout</button>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private WorkoutSession? session;
    private List<ActivityDetail> details = new();
    private List<ExerciseEntry> exercises = new();
    private double distance;
    private int duration;
    private string style = "";
    private string opponent = "";
    private string result = "";

    protected override void OnInitialized()
    {
        session = Db.WorkoutSessions.Find(Id);
        if (session != null)
        {
            details = Db.ActivityDetails
                .Where(d => d.WorkoutSessionId == Id)
                .ToList();

            // Ladda exercises
            int i = 0;
            while (true)
            {
                var name = details.FirstOrDefault(d => d.Key == $"exercise_{i}_name")?.Value;
                if (name == null) break;
                exercises.Add(new ExerciseEntry
                {
                    Name = name,
                    Sets = int.TryParse(details.FirstOrDefault(d => d.Key == $"exercise_{i}_sets")?.Value, out var s) ? s : 0,
                    Reps = int.TryParse(details.FirstOrDefault(d => d.Key == $"exercise_{i}_reps")?.Value, out var r) ? r : 0,
                    Weight = double.TryParse(details.FirstOrDefault(d => d.Key == $"exercise_{i}_weight")?.Value, out var w) ? w : 0
                });
                i++;
            }

            // Ladda andra detaljer
            distance = double.TryParse(details.FirstOrDefault(d => d.Key == "distance")?.Value, out var dist) ? dist : 0;
            duration = int.TryParse(details.FirstOrDefault(d => d.Key == "duration")?.Value, out var dur) ? dur : 0;
            style = details.FirstOrDefault(d => d.Key == "style")?.Value ?? "";
            opponent = details.FirstOrDefault(d => d.Key == "opponent")?.Value ?? "";
            result = details.FirstOrDefault(d => d.Key == "result")?.Value ?? "";
        }
    }

    private void AddExercise() => exercises.Add(new ExerciseEntry());

    private void Save()
    {
        // Ta bort gamla detaljer
        var oldDetails = Db.ActivityDetails
            .Where(d => d.WorkoutSessionId == Id)
            .ToList();
        Db.ActivityDetails.RemoveRange(oldDetails);

        // Spara nya detaljer
        var newDetails = new List<ActivityDetail>();

        if (session!.ActivityType == ActivityType.Gym ||
            session.ActivityType == ActivityType.HomeWorkout ||
            session.ActivityType == ActivityType.Calisthenics)
        {
            for (int i = 0; i < exercises.Count; i++)
            {
                var ex = exercises[i];
                if (string.IsNullOrWhiteSpace(ex.Name)) continue;
                newDetails.Add(new ActivityDetail { WorkoutSessionId = Id, Key = $"exercise_{i}_name", Value = ex.Name });
                newDetails.Add(new ActivityDetail { WorkoutSessionId = Id, Key = $"exercise_{i}_sets", Value = ex.Sets.ToString() });
                newDetails.Add(new ActivityDetail { WorkoutSessionId = Id, Key = $"exercise_{i}_reps", Value = ex.Reps.ToString() });
                newDetails.Add(new ActivityDetail { WorkoutSessionId = Id, Key = $"exercise_{i}_weight", Value = ex.Weight.ToString() });
            }
        }
        else if (session.ActivityType == ActivityType.Running ||
                 session.ActivityType == ActivityType.Cycling)
        {
            newDetails.Add(new ActivityDetail { WorkoutSessionId = Id, Key = "distance", Value = distance.ToString() });
            newDetails.Add(new ActivityDetail { WorkoutSessionId = Id, Key = "duration", Value = duration.ToString() });
        }
        else if (session.ActivityType == ActivityType.Yoga)
        {
            newDetails.Add(new ActivityDetail { WorkoutSessionId = Id, Key = "duration", Value = duration.ToString() });
            newDetails.Add(new ActivityDetail { WorkoutSessionId = Id, Key = "style", Value = style });
        }
        else if (session.ActivityType == ActivityType.TeamSport ||
                 session.ActivityType == ActivityType.Tennis)
        {
            newDetails.Add(new ActivityDetail { WorkoutSessionId = Id, Key = "duration", Value = duration.ToString() });
            newDetails.Add(new ActivityDetail { WorkoutSessionId = Id, Key = "opponent", Value = opponent });
            newDetails.Add(new ActivityDetail { WorkoutSessionId = Id, Key = "result", Value = result });
        }
        else if (session.ActivityType == ActivityType.Swimming)
        {
            newDetails.Add(new ActivityDetail { WorkoutSessionId = Id, Key = "distance", Value = distance.ToString() });
            newDetails.Add(new ActivityDetail { WorkoutSessionId = Id, Key = "duration", Value = duration.ToString() });
        }
        else
        {
            newDetails.Add(new ActivityDetail { WorkoutSessionId = Id, Key = "duration", Value = duration.ToString() });
        }

        Db.ActivityDetails.AddRange(newDetails);
        Db.SaveChanges();
        Nav.NavigateTo($"/workouts/details/{Id}");
    }

    private void Delete()
    {
        if (session != null)
        {
            var details = Db.ActivityDetails
                .Where(d => d.WorkoutSessionId == Id)
                .ToList();
            Db.ActivityDetails.RemoveRange(details);
            Db.WorkoutSessions.Remove(session);
            Db.SaveChanges();
            Nav.NavigateTo("/workouts");
        }
    }

    private string GetActivityName(ActivityType? t) => t switch
    {
        ActivityType.HomeWorkout => "Home Workout",
        ActivityType.TeamSport => "Team Sport",
        _ => t?.ToString() ?? "Unknown"
    };

    private class ExerciseEntry
    {
        public string Name { get; set; } = "";
        public int Sets { get; set; } = 3;
        public int Reps { get; set; } = 10;
        public double Weight { get; set; }
    }
}