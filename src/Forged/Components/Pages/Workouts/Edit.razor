@page "/workouts/edit/{Id:int}"
@rendermode InteractiveServer
@using Forged.Data
@using Forged.Models
@inject AppDbContext Db
@inject NavigationManager Nav

<PageTitle>FORGED – Edit Workout</PageTitle>

<div class="page-header">
    <h1>Edit Workout</h1>
</div>

@if (session == null)
{
    <p class="text-muted">Loading...</p>
}
else
{
    <div class="card" style="max-width:700px;">
        <div class="form-group">
            <label class="form-label">Date</label>
            <input type="date" class="form-control" @bind="session.Date" />
        </div>

        <div class="form-group">
            <label class="form-label">Activity Type</label>
            <select class="form-control" @bind="session.ActivityType">
                @foreach (var type in Enum.GetValues<ActivityType>())
                {
                    <option value="@type">@type</option>
                }
            </select>
        </div>

        <div class="form-group">
            <label class="form-label">Notes</label>
            <textarea class="form-control" rows="3" @bind="session.Notes"></textarea>
        </div>

        <div class="form-actions">
            <button class="btn-primary" @onclick="Save">Save Changes</button>
            <a href="/workouts/details/@Id" class="btn-secondary">Cancel</a>
        </div>

        <div class="delete-confirm">
            <span class="text-muted" style="font-size:13px;">Danger zone</span>
            <button class="btn-danger" @onclick="Delete">Delete Workout</button>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private WorkoutSession? session;

    protected override void OnInitialized()
    {
        session = Db.WorkoutSessions.Find(Id);
    }

    private void Save()
    {
        Db.SaveChanges();
        Nav.NavigateTo($"/workouts/details/{Id}");
    }

    private void Delete()
    {
        if (session != null)
        {
            var details = Db.ActivityDetails
                .Where(d => d.WorkoutSessionId == Id)
                .ToList();
            Db.ActivityDetails.RemoveRange(details);
            Db.WorkoutSessions.Remove(session);
            Db.SaveChanges();
            Nav.NavigateTo("/workouts");
        }
    }
}